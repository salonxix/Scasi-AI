# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth (Gmail API & Authentication)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Azure AD Authentication
AZURE_AD_CLIENT_ID=your_azure_ad_client_id
AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret
AZURE_AD_TENANT_ID=your_azure_ad_tenant_id

# ── LLM API Keys ───────────────────────────────────────────────────────
# Each key is scoped to a specific model group so rate limits are isolated.

# Groq — Llama 3.1 8B & Llama 3.3 70B  (route, reply)
GROQ_API_KEY=your_groq_api_key

# OpenRouter Key 1 — GPT-OSS 120B, Gemini Flash, DeepSeek V3  (extract, summarize, rerank)
OPENROUTER_API_KEY_GPT_OSS=your_openrouter_key_for_gpt_oss

# OpenRouter Key 2 — Nemotron 30B, Qwen 32B, Qwen 72B  (classify)
OPENROUTER_API_KEY_NEMOTRON=your_openrouter_key_for_nemotron

# OpenRouter Key 3 — Qwen3 VL 235B Thinking, Gemini Pro  (judge)
OPENROUTER_API_KEY_QWEN3=your_openrouter_key_for_qwen3

# OpenRouter Key 4 — Hunter Alpha  (universal fallback)
OPENROUTER_API_KEY_HUNTER=your_openrouter_key_for_hunter

# Gemini — gemini-embedding-001  (embed only, free tier)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (if used by other parts of the app)
OPENAI_API_KEY=your_openai_api_key
